        "### 3. Document Loading and Text Chunking\n",
        "\n",
        "This section defines functions to load documents (PDF and TXT) and split them into smaller, overlapping chunks. Text chunking is important for RAG to ensure that relevant context can be retrieved efficiently and fits within the LLM's input limit."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 383
        },
        "id": "2668831a",
        "outputId": "ed2826a4-59f0-4320-ac8f-7a4b15508e41"
      },
      "source": [
        "import PyPDF2\n",
        "import os\n",
        "\n",
        "def load_document(file_path):\n",
        "    text = \"\"\n",
        "    if file_path.endswith('.pdf'):\n",
        "        with open(file_path, 'rb') as f:\n",
        "            reader = PyPDF2.PdfReader(f)\n",
        "            for page in reader.pages:\n",
        "                text += page.extract_text() if page.extract_text() else \"\"\n",
        "    elif file_path.endswith('.txt'):\n",
        "        with open(file_path, 'r', encoding='utf-8') as f:\n",
        "            text = f.read()\n",
        "    else:\n",
        "        raise ValueError(\"Unsupported file type. Only .txt and .pdf are supported.\")\n",
        "    return text\n",
        "\n",
        "def split_text(text, chunk_size=500, chunk_overlap=50):\n",
        "    # A simple character-based text splitter\n",
        "    chunks = []\n",
        "    start = 0\n",
        "    while start < len(text):\n",
        "        end = start + chunk_size\n",
        "        chunk = text[start:end]\n",
        "        chunks.append(chunk)\n",
        "        start += chunk_size - chunk_overlap\n",
        "        if start >= len(text) - chunk_overlap and len(text) - start > 0:\n",
        "            # Add the last bit if it's smaller than chunk_size but still exists\n",
        "            chunks.append(text[start:])\n",
        "            break\n",
        "    return [chunk.strip() for chunk in chunks if chunk.strip()] # Remove empty chunks\n",
        "\n",
        "# List to store all document chunks\n",
        "all_document_chunks = []\n",
        "\n",
        "# Load and chunk the example document\n",
        "print(\"Loading example document...\")\n",
        "example_text = load_document('example_document.txt')\n",
        "example_chunks = split_text(example_text)\n",
        "all_document_chunks.extend(example_chunks)\n",
        "print(f\"Loaded {len(example_chunks)} chunks from example_document.txt\")\n",
        "\n",
        "print(\"\\n--- You can now upload your own files ---\")\n"
